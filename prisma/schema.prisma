// DigiPlein — datamodel (mvp-spec §6). Engelse tabel-/kolomnamen, NL UI-labels.
// Enums UPPER_SNAKE; conversie naar labels uitsluitend via lib/enums.ts (ADR-0004).
// Alle tabellen worden in de MVP aangelegd; rooster-/trajecttabellen krijgen pas
// in M3/M4 een UI ("uitbreiden zonder verbouwing"). CHECK-constraints en de
// partial unique index (één ACTIEF traject per client+course) staan als raw SQL
// in de init-migratie — Prisma kent die niet declaratief.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum StaffRole {
  ADMIN
  STAFF
}

enum CourseAssessment {
  KLIK_EN_TIK
  LES_OP_MAAT
  NOG_BEPALEN
}

enum ClientStatus {
  AANGEMELD
  INTAKE
  ACTIEF
  AFGEROND
  GESTOPT
}

enum TrackStatus {
  ACTIEF
  AFGEROND
  GESTOPT
}

enum LessonStatus {
  GEPLAND
  VERVALLEN
}

enum RosterStatus {
  INGEPLAND
  AFGEMELD
  AANWEZIG
  NO_SHOW
}

enum ActorType {
  STAFF
  CHAT_AGENT
  SYSTEM
}

model StaffMember {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         StaffRole @default(STAFF)
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@map("staff_members")
}

model Volunteer {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  email           String?       @unique
  phone           String?
  prefersTuesday  Boolean       @default(false) @map("prefers_tuesday")
  prefersThursday Boolean       @default(false) @map("prefers_thursday")
  frequencyNote   String?       @map("frequency_note")
  ndaSignedAt     DateTime?     @map("nda_signed_at") @db.Date
  isActive        Boolean       @default(true) @map("is_active")
  notes           String?
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  rosterEntries   RosterEntry[]
  absences        Absence[]

  @@map("volunteers")
}

model Client {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName         String           @map("first_name")
  lastName          String?          @map("last_name")
  phone             String?
  email             String?
  learningWish      String?          @map("learning_wish")
  assessment        CourseAssessment @default(NOG_BEPALEN)
  status            ClientStatus     @default(AANGEMELD)
  oefenenUsername   String?          @map("oefenen_username")
  consentExtrasAt   DateTime?        @map("consent_extras_at") @db.Timestamptz
  consentExtrasNote String?          @map("consent_extras_note")
  lastAttendedOn    DateTime?        @map("last_attended_on") @db.Date
  notes             String?
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime         @updatedAt @map("updated_at") @db.Timestamptz
  learningTracks    LearningTrack[]

  @@map("clients")
}

model Course {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code           String          @unique
  name           String
  description    String?
  maxSessions    Int?            @map("max_sessions")
  sessionMinutes Int             @default(120) @map("session_minutes")
  onTuesday      Boolean         @default(true) @map("on_tuesday")
  onThursday     Boolean         @default(true) @map("on_thursday")
  isActive       Boolean         @default(true) @map("is_active")
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz
  learningTracks LearningTrack[]

  @@map("courses")
}

model LearningTrack {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId    String       @map("client_id") @db.Uuid
  courseId    String       @map("course_id") @db.Uuid
  goal        String?
  status      TrackStatus  @default(ACTIEF)
  startedOn   DateTime     @map("started_on") @db.Date
  endedOn     DateTime?    @map("ended_on") @db.Date
  nextStep    String?      @map("next_step")
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  client      Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Restrict)
  attendances Attendance[]

  @@map("learning_tracks")
}

model LessonDate {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  date          DateTime      @unique @db.Date
  startsAt      DateTime      @default(dbgenerated("'10:00:00'::time")) @map("starts_at") @db.Time
  endsAt        DateTime      @default(dbgenerated("'12:00:00'::time")) @map("ends_at") @db.Time
  status        LessonStatus  @default(GEPLAND)
  note          String?
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  rosterEntries RosterEntry[]
  attendances   Attendance[]

  @@map("lesson_dates")
}

model RosterEntry {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lessonDateId String       @map("lesson_date_id") @db.Uuid
  volunteerId  String       @map("volunteer_id") @db.Uuid
  status       RosterStatus @default(INGEPLAND)
  note         String?
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  lessonDate   LessonDate   @relation(fields: [lessonDateId], references: [id])
  volunteer    Volunteer    @relation(fields: [volunteerId], references: [id])

  @@unique([lessonDateId, volunteerId])
  @@map("roster_entries")
}

model Absence {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  volunteerId String    @map("volunteer_id") @db.Uuid
  startsOn    DateTime  @map("starts_on") @db.Date
  endsOn      DateTime  @map("ends_on") @db.Date
  note        String?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  volunteer   Volunteer @relation(fields: [volunteerId], references: [id])

  @@map("absences")
}

model Attendance {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lessonDateId    String        @map("lesson_date_id") @db.Uuid
  learningTrackId String        @map("learning_track_id") @db.Uuid
  attended        Boolean       @default(true)
  note            String?
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  lessonDate      LessonDate    @relation(fields: [lessonDateId], references: [id])
  learningTrack   LearningTrack @relation(fields: [learningTrackId], references: [id], onDelete: Cascade)

  @@unique([lessonDateId, learningTrackId])
  @@map("attendances")
}

model AuditLog {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorType ActorType @map("actor_type")
  actorId   String?   @map("actor_id") @db.Uuid
  action    String
  entity    String
  entityId  String?   @map("entity_id") @db.Uuid
  summary   String
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@map("audit_logs")
}
