# DigiPlein — lokale ontwikkelomgeving.
# Hardstop (plan §0): uitsluitend dummydata tot FG-akkoord — nooit echte cliëntgegevens.
# Kopieer naar .env.local en vul in.

# PostgreSQL (lokaal; docker-compose.dev.yml volgt in ST-003)
DATABASE_URL="postgresql://digiplein:digiplein@localhost:5432/digiplein?schema=public"

# iron-session cookie-secret — minimaal 32 tekens (ST-004)
SESSION_SECRET=""

# Basis-URL van de app (auth-redirects)
APP_BASE_URL="http://localhost:3000"
